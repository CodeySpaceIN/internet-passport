{
  "name": "@internet-passport/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/client.ts",
  "exports": {
    ".": "./src/client.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:drift": "prisma migrate diff --from-url \"$DATABASE_URL\" --to-schema-datamodel prisma/schema.prisma --exit-code",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "prisma": "^6.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
